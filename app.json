{
  "expo": {
    "name": "Sugar",
    "slug": "sugar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sugar",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "io.minhthang.sugar",
      "supportsTablet": true
    },
    "android": {
      "package": "io.minhthang.sugar",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0FA36B",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0FA36B",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160
        }
      ],
      "expo-sqlite",
      "expo-localization",
      [
        "expo-notifications",
        {
          "color": "#0FA36B"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f039fdd4-0914-43c3-96a3-ef20ac9d95f3"
      },
      "revenueCat": {}
    },
    "owner": "minhthang_dunia"
  }
}
